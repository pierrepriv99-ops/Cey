{
  "name": "cryos-station",
  "version": "0.1.0",
  "description": "CryOS Station - Desktop Client",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.cryos.station",
    "productName": "CryOS Station",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "electron": "^28.1.0",
    "electron-log": "^5.1.0",
    "electron-store": "^8.1.0"
  }
}